{
  "name": "apify-bitcoin-scraper",
  "version": "1.0.0",
  "description": "Bitcoin market scraper using Apify + Crawlee, integrated with Coin Smith PSBT builder",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "test": "jest",
    "scrape:all": "ts-node src/run-all-actors.ts",
    "aggregate": "ts-node src/aggregator/aggregate.ts",
    "build-psbt": "ts-node src/build-transaction.ts",
    "lint": "eslint src --ext .ts"
